# =============================================================================
# CLARISA - CGSpace Mapping - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your real credentials
# NEVER upload the .env file to the repository

# =============================================================================
# CLARISA API
# =============================================================================
CLARISA_API_URL=https://api.clarisa.cgiar.org/api/institutions

# =============================================================================
# Supabase
# =============================================================================
# Obtain these credentials from: Settings > API in your Supabase project
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# =============================================================================
# AWS Bedrock (Embeddings & Web Search Analysis)
# =============================================================================
# Used for:
# 1. Embeddings with Amazon Titan (semantic search in CLARISA)
# 2. Web results analysis with Claude Sonnet 4.5 (Phase 2 of web search)
# Make sure you have access to us-east-1 and the necessary models:
#   - amazon.titan-embed-text-v2:0 (embeddings)
#   - us.anthropic.claude-sonnet-4-5-20250929-v1:0 (analysis)
AWS_ACCESS_KEY_ID_BR=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY_BR=your-aws-secret-access-key
AWS_REGION=us-east-1

# =============================================================================
# OpenAI (Web Search Phase 1: Information Gathering)
# =============================================================================
# Obtain your API key from: https://platform.openai.com/api-keys
# Used for exploratory web search (Phase 1) when no match is found in CLARISA
# The gpt-5-mini model gathers information that is then analyzed by Claude in Phase 2
OPENAI_API_KEY=your-openai-api-key