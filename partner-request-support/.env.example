# =============================================================================
# CLARISA - CGSpace Mapping - Variables de Entorno
# =============================================================================
# Copia este archivo a .env y completa con tus credenciales reales
# NUNCA subas el archivo .env al repositorio

# =============================================================================
# API de CLARISA
# =============================================================================
CLARISA_API_URL=https://api.clarisa.cgiar.org/api/institutions

# =============================================================================
# Supabase
# =============================================================================
# Obtén estas credenciales desde: Settings > API en tu proyecto de Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu-clave-anon-o-service-role-key

# =============================================================================
# AWS Bedrock (Amazon Titan)
# =============================================================================
# Estas se configuran en config_util.py
# Asegúrate de tener acceso a us-east-1 y el modelo amazon.titan-embed-text-v2:0
AWS_ACCESS_KEY_ID_BR=tu-aws-access-key-id
AWS_SECRET_ACCESS_KEY_BR=tu-aws-secret-access-key

# =============================================================================
# OpenAI (Opcional - solo si usas funcionalidades adicionales)
# =============================================================================
OPENAI_API_KEY=tu-openai-api-key
